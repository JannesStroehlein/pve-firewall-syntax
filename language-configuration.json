{
  "comments": {
    "lineComment": {
      "comment": "#",
      "noIndent": false
    }
  },
  "brackets": [["[", "]"]],
  "autoClosingPairs": [{ "open": "[", "close": "]" }],
  "surroundingPairs": [{ "open": "[", "close": "]" }],
  "folding": {
    "markers": {
      "start": "^\\s*\\[",
      "end": "^(?=\\s*\\[)"
    }
  }
}
